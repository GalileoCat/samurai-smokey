<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Samurai Smokey Archive on Samurai Smokey</title><link>/archive/samuraismokey/</link><description>Recent content in Samurai Smokey Archive on Samurai Smokey</description><generator>Hugo</generator><language>en-us</language><atom:link href="/archive/samuraismokey/index.xml" rel="self" type="application/rss+xml"/><item><title/><link>/archive/samuraismokey/2020-ch1/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>/archive/samuraismokey/2020-ch1/</guid><description>&lt;style&gt;
 /* 1. Force the page background to be the nightmare haze */
 body {
 background: #000 !important;
 }

 /* 2. The Particle Layer */
 .nightmare-overlay {
 position: fixed;
 top: 0;
 left: 0;
 width: 100%;
 height: 100%;
 pointer-events: none;
 z-index: 0;
 background-image: 
 radial-gradient(4px 4px at 10% 10%, #8a2be2, transparent),
 radial-gradient(6px 6px at 90% 20%, #4b0082, transparent),
 radial-gradient(3px 3px at 15% 50%, #9932cc, transparent),
 radial-gradient(5px 5px at 85% 80%, #800080, transparent),
 radial-gradient(4px 4px at 50% 90%, #8a2be2, transparent);
 background-size: 100% 100%;
 animation: nightmareDrift 15s ease-in-out infinite alternate;
 }

 @keyframes nightmareDrift {
 from { transform: scale(1); opacity: 0.4; }
 to { transform: scale(1.2); opacity: 0.8; }
 }

 /* 3. Force the reader to stay on top and be transparent */
 .nightmare-content {
 position: relative;
 z-index: 2;
 }

 .nightmare-content .vertical-reader, 
 .nightmare-content .vertical-reader p {
 background: transparent !important;
 }

 /* 4. Add a purple glow to the images so they don't look "flat" */
 .nightmare-content img {
 box-shadow: 0 0 30px rgba(138, 43, 226, 0.3) !important;
 margin-bottom: 0 !important;
 }
&lt;/style&gt;
&lt;div class="nightmare-overlay"&gt;&lt;/div&gt;
&lt;div class="nightmare-content"&gt;
&lt;p&gt;The start of Smokey and Sage&amp;rsquo;s journey begins here!&lt;/p&gt;</description></item><item><title/><link>/archive/samuraismokey/2020-ch2/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>/archive/samuraismokey/2020-ch2/</guid><description>&lt;style&gt;
