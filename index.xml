    <item>
      <title></title>
      <link>//localhost:1313/archive/2020-ch1/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/archive/2020-ch1/</guid>
      <description>&lt;style&gt;&#xD;&#xA;    /* 1. Force the page background to be the nightmare haze */&#xD;&#xA;    body {&#xD;&#xA;        background: #000 !important;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    /* 2. The Particle Layer */&#xD;&#xA;    .nightmare-overlay {&#xD;&#xA;        position: fixed;&#xD;&#xA;        top: 0;&#xD;&#xA;        left: 0;&#xD;&#xA;        width: 100%;&#xD;&#xA;        height: 100%;&#xD;&#xA;        pointer-events: none;&#xD;&#xA;        z-index: 0;&#xD;&#xA;        background-image: &#xD;&#xA;            radial-gradient(4px 4px at 10% 10%, #8a2be2, transparent),&#xD;&#xA;            radial-gradient(6px 6px at 90% 20%, #4b0082, transparent),&#xD;&#xA;            radial-gradient(3px 3px at 15% 50%, #9932cc, transparent),&#xD;&#xA;            radial-gradient(5px 5px at 85% 80%, #800080, transparent),&#xD;&#xA;            radial-gradient(4px 4px at 50% 90%, #8a2be2, transparent);&#xD;&#xA;        background-size: 100% 100%;&#xD;&#xA;        animation: nightmareDrift 15s ease-in-out infinite alternate;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    @keyframes nightmareDrift {&#xD;&#xA;        from { transform: scale(1); opacity: 0.4; }&#xD;&#xA;        to { transform: scale(1.2); opacity: 0.8; }&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    /* 3. Force the reader to stay on top and be transparent */&#xD;&#xA;    .nightmare-content {&#xD;&#xA;        position: relative;&#xD;&#xA;        z-index: 2;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .nightmare-content .vertical-reader, &#xD;&#xA;    .nightmare-content .vertical-reader p {&#xD;&#xA;        background: transparent !important;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    /* 4. Add a purple glow to the images so they don&#39;t look &#34;flat&#34; */&#xD;&#xA;    .nightmare-content img {&#xD;&#xA;        box-shadow: 0 0 30px rgba(138, 43, 226, 0.3) !important;&#xD;&#xA;        margin-bottom: 0 !important;&#xD;&#xA;    }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;div class=&#34;nightmare-overlay&#34;&gt;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;nightmare-content&#34;&gt;&#xD;&#xA;&lt;p&gt;The start of Smokey and Sage&amp;rsquo;s journey begins here!&lt;/p&gt;</description>
    </item>
